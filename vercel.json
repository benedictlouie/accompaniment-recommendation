{
  "version": 2,
  "builds": [
    { "src": "api/index.py",   "use": "@vercel/python", "config": { "runtime": "python3.11" } },
    { "src": "public/**/*",    "use": "@vercel/static"  }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/index.py"          },
    { "src": "/piano",         "dest": "/public/piano.html"     },
    { "src": "/harmoniser",    "dest": "/public/harmoniser.html" },
    { "src": "/",              "dest": "/public/index.html"     }
  ]
}
